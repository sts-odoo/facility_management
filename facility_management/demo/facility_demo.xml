        <field name="stop_datetime" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 12:00:00')"/>
        <field name="description">LINFO1101 — Introduction lecture.</field>
        <field name="student_group_ids" eval="[(6, 0, [ref('group_linfo11')])]"/>
    </record>
    <record id="booking_demo_4" model="facility.booking">
        <field name="room_id" ref="room_agor01"/>
        <field name="organizer_id" ref="base.user_demo"/>
        <field name="start_datetime" eval="(datetime.now() + timedelta(days=4)).strftime('%Y-%m-%d 09:00:00')"/>
        <field name="stop_datetime" eval="(datetime.now() + timedelta(days=4)).strftime('%Y-%m-%d 11:00:00')"/>
        <field name="description">LDROI1001 — Lecture.</field>
        <field name="student_group_ids" eval="[(6, 0, [ref('group_droi13')])]"/>
