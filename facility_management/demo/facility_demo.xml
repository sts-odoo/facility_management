        <field name="room_id" ref="room_med"/>
        <field name="organizer_id" ref="base.user_admin"/>
        <field name="start_datetime" eval="(datetime.now() + timedelta(days=5)).strftime('%Y-%m-%d 13:00:00')"/>
        <field name="stop_datetime" eval="(datetime.now() + timedelta(days=5)).strftime('%Y-%m-%d 15:00:00')"/>
        <field name="description">WMDS1101 — Lecture (Woluwe).</field>
        <field name="student_group_ids" eval="[(6, 0, [ref('group_math12')])]"/>
    </record>
    <record id="booking_demo_6" model="facility.booking">
        <field name="room_id" ref="room_mons_aud"/>
        <field name="organizer_id" ref="base.user_demo"/>
        <field name="start_datetime" eval="(datetime.now() + timedelta(days=6)).strftime('%Y-%m-%d 08:00:00')"/>
        <field name="stop_datetime" eval="(datetime.now() + timedelta(days=6)).strftime('%Y-%m-%d 10:00:00')"/>
        <field name="description">MONS — Plenary session.</field>
        <field name="student_group_ids" eval="[(6, 0, [ref('group_sinf12')])]"/>
    </record>
    <record id="booking_demo_7" model="facility.booking">
        <field name="room_id" ref="room_cycl01"/>
        <field name="organizer_id" ref="base.user_admin"/>
        <field name="start_datetime" eval="(datetime.now() + timedelta(days=7)).strftime('%Y-%m-%d 14:00:00')"/>
        <field name="stop_datetime" eval="(datetime.now() + timedelta(days=7)).strftime('%Y-%m-%d 17:00:00')"/>
        <field name="description">LEPL1503 — Practical work.</field>
        <field name="student_group_ids" eval="[(6, 0, [ref('group_epl11')])]"/>
    </record>
    <record id="booking_demo_8" model="facility.booking">
        <field name="room_id" ref="room_wol_cl1"/>
        <field name="organizer_id" ref="base.user_demo"/>
        <field name="start_datetime" eval="(datetime.now() + timedelta(days=8)).strftime('%Y-%m-%d 10:00:00')"/>
