<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_facility" model="ir.module.category">
        <field name="name">Facility Management</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_facility" model="res.groups.privilege">
        <field name="name">Facility Management</field>
        <field name="category_id" ref="module_category_facility"/>
        <field name="sequence">20</field>
    </record>

    <record id="group_facility_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_facility"/>
        <field name="comment">Can create bookings and read configuration.</field>
    </record>

    <record id="group_facility_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_facility"/>
        <field name="implied_ids" eval="[(4, ref('group_facility_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Full access to sites, rooms, equipment, constraints and bookings.</field>
    </record>
</odoo>
