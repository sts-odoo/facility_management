<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_facility_student_group_list" model="ir.ui.view">
        <field name="name">facility.student.group.list</field>
        <field name="model">facility.student.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="member_count" string="Members"/>
            </list>
        </field>
    </record>

    <record id="view_facility_student_group_form" model="ir.ui.view">
        <field name="name">facility.student.group.form</field>
        <field name="model">facility.student.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. EPL11"/></h1>
                    </div>
                    <group>
                        <field name="code"/>
                    </group>
                    <notebook>
                        <page string="Members" name="members">
                            <field name="member_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_facility_student_group" model="ir.actions.act_window">
        <field name="name">Student Groups</field>
        <field name="res_model">facility.student.group</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
