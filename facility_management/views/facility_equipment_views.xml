<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_facility_equipment_list" model="ir.ui.view">
        <field name="name">facility.equipment.list</field>
        <field name="model">facility.equipment</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_facility_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">facility.equipment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
