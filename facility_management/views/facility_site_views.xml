<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_facility_site_list" model="ir.ui.view">
        <field name="name">facility.site.list</field>
        <field name="model">facility.site</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="country_id"/>
                <field name="room_count"/>
            </list>
        </field>
    </record>

    <record id="view_facility_site_form" model="ir.ui.view">
        <field name="name">facility.site.form</field>
        <field name="model">facility.site</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Site name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id"/>
                            <field name="country_id"/>
                        </group>
                        <group string="Geolocation">
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rooms" name="rooms">
                            <field name="room_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="capacity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_facility_site" model="ir.actions.act_window">
        <field name="name">Sites</field>
        <field name="res_model">facility.site</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
